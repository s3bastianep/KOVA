# Base de datos (Railway PostgreSQL la inyecta automáticamente como DATABASE_URL)
DATABASE_URL="postgresql://kova:kova_dev_password@localhost:5432/kova_talent_os?schema=public"

# Secreto para firmar sesiones (cambia esto en producción)
JWT_SECRET="cambia-esto-por-un-texto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Vista previa local sin PostgreSQL (solo desarrollo)
USE_MOCK=true

# API interna (mismo servidor Next.js)
NEXT_PUBLIC_API_URL=/api
